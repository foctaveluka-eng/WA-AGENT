modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=5000 node --enable-source-maps /home/runner/workspace/artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "cd /home/runner/workspace && pnpm install --frozen-lockfile && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/whatsapp-agent run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "artifacts/api-server: API Server"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
API_PORT = "8080"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080
